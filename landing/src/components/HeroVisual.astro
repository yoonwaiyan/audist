---
import { withBase } from '../lib/paths'
---

<div class="hero-visual hero-cover-visual" aria-hidden="true">
  <div class="hero-cover-backdrop"></div>

  <div class="hero-cover-frame">
    <picture>
      <source
        srcset={withBase('/images/hero-desktop-cover.avif')}
        type="image/avif"
      />
      <source
        srcset={withBase('/images/hero-desktop-cover.webp')}
        type="image/webp"
      />
      <img
        class="hero-cover-image"
        src={withBase('/images/hero-desktop-cover.png')}
        alt=""
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1600"
        height="1188"
        sizes="(max-width: 960px) 100vw, 704px"
      />
    </picture>
  </div>
</div>
