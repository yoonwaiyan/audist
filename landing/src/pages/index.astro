---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import HeroVisual from '../components/HeroVisual.astro'
import ShotCard from '../components/ShotCard.astro'
import { featureCards, screenshotCards, siteConfig } from '../data/site'
import { withBase } from '../lib/paths'
---

<BaseLayout title="Audist | Local-first meeting recorder" path="/">
  <Header />

  <main>
    <section class="hero-section">
      <div class="container hero-container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Private by default</p>
          <h1>
            Capture meetings.
            <br />
            Transcribe locally.
            <br />
            Get clear notes.
          </h1>
          <p class="lede">
            Audist is a desktop recorder that keeps audio on device, transcribes with whisper.cpp,
            and lets you choose the summary model that fits your workflow.
            <span class="hero-lede-underline">Windows and Linux support are in active progress.</span>
          </p>

          <div class="hero-actions">
            <a class="button button-primary" href={withBase('/download/')}>Download Audist</a>
          </div>
        </div>

        <HeroVisual />
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Core workflow</p>
          <h2>A local-first workflow for meeting capture and notes.</h2>
          <p>
            Audist is built for local audio capture, local transcription with whisper.cpp, and AI
            meeting summaries generated through OpenAI, Anthropic, or compatible providers. The
            interface stays spare and desktop-native so repeated daily meetings still feel fast and
            readable under pressure.
          </p>
        </div>

        <div class="feature-grid">
          {featureCards.map((feature) => (
            <article class="feature-card">
              <div class="feature-icon" aria-hidden="true">
                {feature.icon === 'wave' && (
                  <svg viewBox="0 0 24 24" fill="none">
                    <rect x="3" y="10" width="2" height="4" rx="1"></rect>
                    <rect x="7" y="6" width="2" height="12" rx="1"></rect>
                    <rect x="11" y="4" width="2" height="16" rx="1"></rect>
                    <rect x="15" y="8" width="2" height="8" rx="1"></rect>
                    <rect x="19" y="11" width="2" height="2" rx="1"></rect>
                  </svg>
                )}
                {feature.icon === 'spark' && (
                  <svg viewBox="0 0 24 24" fill="none">
                    <path d="M12 3 13.9 8.1 19 10l-5.1 1.9L12 17l-1.9-5.1L5 10l5.1-1.9L12 3Z"></path>
                    <path d="M18.5 3.5 19.2 5.3 21 6l-1.8.7-.7 1.8-.7-1.8L16 6l1.8-.7.7-1.8Z"></path>
                  </svg>
                )}
                {feature.icon === 'grid' && (
                  <svg viewBox="0 0 24 24" fill="none">
                    <rect x="4" y="4" width="6" height="6" rx="1.5"></rect>
                    <rect x="14" y="4" width="6" height="6" rx="1.5"></rect>
                    <rect x="4" y="14" width="6" height="6" rx="1.5"></rect>
                    <rect x="14" y="14" width="6" height="6" rx="1.5"></rect>
                  </svg>
                )}
              </div>
              <h3>{feature.title}</h3>
              <p>{feature.body}</p>
            </article>
          ))}
        </div>

        <p class="platform-note">
          Audist is currently optimized for macOS. Native Windows and Linux releases are planned
          next so the same local-first workflow can ship across desktop platforms.
        </p>
      </div>
    </section>

    <section class="section section-shots">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Product surfaces</p>
          <h2>Three views, one visual system.</h2>
          <p>
            The landing page mirrors the app’s existing brand: void backgrounds, iris accents,
            dense panels, and just enough glow to make live state feel active.
          </p>
        </div>

        <div class="shot-grid">
          <ShotCard {...screenshotCards[2]} variant="prefs" />
          <ShotCard {...screenshotCards[0]} variant="record" />
          <ShotCard {...screenshotCards[1]} variant="review" />
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container narrative-grid">
        <article class="info-panel">
          <p class="eyebrow">Output</p>
          <h2>Summaries in Markdown.</h2>
          <p>
            Audist generates summaries in Markdown, which makes the output easy to reuse across
            common note-taking workflows instead of locking it into a custom format.
          </p>
          <div class="note-tags">
            <span>Markdown summaries</span>
            <span>Portable format</span>
          </div>
        </article>

        <aside class="panel markdown-panel" aria-label="Markdown output preview">
          <div class="markdown-sheet" aria-hidden="true">
            <div class="markdown-row">
              <div class="markdown-glyph hash"></div>
              <div class="markdown-line heading"></div>
            </div>
            <div class="markdown-gap"></div>
            <div class="markdown-row">
              <div class="markdown-glyph dash"></div>
              <div class="markdown-line bullet wide"></div>
            </div>
            <div class="markdown-row">
              <div class="markdown-glyph dash"></div>
              <div class="markdown-line bullet medium"></div>
            </div>
            <div class="markdown-row">
              <div class="markdown-glyph dash"></div>
              <div class="markdown-line bullet short"></div>
            </div>
            <div class="markdown-gap"></div>
            <div class="markdown-row">
              <div class="markdown-glyph hash small"></div>
              <div class="markdown-line subheading"></div>
            </div>
            <div class="markdown-row">
              <div class="markdown-glyph checkbox"></div>
              <div class="markdown-line medium"></div>
            </div>
            <div class="markdown-row">
              <div class="markdown-glyph checkbox"></div>
              <div class="markdown-line wide"></div>
            </div>
            <div class="markdown-gap"></div>
            <div class="markdown-row">
              <div class="markdown-glyph code"></div>
              <div class="markdown-line code"></div>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="container narrative-grid">
        <article class="info-panel">
          <p class="eyebrow">Storage</p>
          <h2>Choose where notes land.</h2>
          <p>
            You can choose the save directory, so session notes can drop straight into an Obsidian
            vault or any folder-based knowledge system without an extra export step.
          </p>
          <div class="note-tags">
            <span>Custom save directory</span>
            <span>Obsidian-friendly</span>
          </div>
        </article>

        <aside class="panel markdown-panel" aria-label="Storage destination preview">
          <div class="picker-sheet" aria-hidden="true">
            <div class="picker-bar">
              <div class="picker-dots">
                <span></span>
                <span></span>
                <span></span>
              </div>
              <div class="picker-search"></div>
            </div>
            <div class="picker-body">
              <div class="picker-sidebar">
                <div class="picker-nav-line short"></div>
                <div class="picker-nav-line wide active"></div>
                <div class="picker-nav-line medium"></div>
                <div class="picker-nav-line short"></div>
              </div>
              <div class="picker-main">
                <div class="picker-grid">
                  <div class="picker-card">
                    <div class="picker-folder accent"></div>
                    <div class="picker-card-line medium"></div>
                  </div>
                  <div class="picker-card">
                    <div class="picker-folder"></div>
                    <div class="picker-card-line short"></div>
                  </div>
                  <div class="picker-card selected">
                    <div class="picker-folder accent"></div>
                    <div class="picker-card-line wide"></div>
                  </div>
                  <div class="picker-card">
                    <div class="picker-folder"></div>
                    <div class="picker-card-line medium"></div>
                  </div>
                </div>
                <div class="picker-footer">
                  <div class="picker-selection"></div>
                  <div class="picker-button"></div>
                </div>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="container narrative-grid">
        <article class="info-panel">
          <p class="eyebrow">Privacy</p>
          <h2>Your recordings stay on your machine.</h2>
          <p>
            Audist uses whisper.cpp locally for transcription, so raw meeting audio never has to be
            uploaded just to get a transcript. If you use a remote model for summaries, that choice
            stays explicit and configurable.
          </p>
        </article>

        <div class="privacy-visual" aria-hidden="true">
          <div class="privacy-orbit privacy-orbit-large"></div>
          <div class="privacy-orbit privacy-orbit-small"></div>
          <div class="privacy-core">
            <div class="privacy-core-ring"></div>
            <div class="privacy-lock">
              <div class="privacy-lock-shackle"></div>
              <div class="privacy-lock-body"></div>
            </div>
          </div>
          <div class="privacy-chip privacy-chip-a">On-device audio</div>
          <div class="privacy-chip privacy-chip-b">Local transcription</div>
          <div class="privacy-chip privacy-chip-c">Explicit model choice</div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container cta-panel">
        <div>
          <p class="eyebrow">Ready to try it</p>
          <h2>Try the current macOS release and follow along as Windows and Linux land next.</h2>
        </div>
        <div class="cta-actions">
          <a class="button button-primary" href={withBase('/download/')}>Latest downloads</a>
          <a class="button button-secondary" href={withBase('/release-notes/')}>Release notes</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
