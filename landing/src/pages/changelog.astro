---
import BaseLayout from '../layouts/BaseLayout.astro'
import { withBase } from '../lib/paths'

const releaseNotesHref = withBase('/release-notes/')
---

<BaseLayout
  title="Audist release notes"
  description="Release notes for Audist, rendered statically from GitHub Releases data."
  path="/changelog/"
>
  <main class="page-main">
    <section class="page-hero">
      <div class="container page-hero-inner">
        <article class="release-card">
          <p class="eyebrow">Page moved</p>
          <h1>Release notes</h1>
          <p class="lede">
            The changelog has been renamed to Release notes. This page stays here to preserve older
            links.
          </p>
          <a class="button button-primary" href={releaseNotesHref}>Open release notes</a>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>
