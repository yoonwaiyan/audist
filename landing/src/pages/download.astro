---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import { getReleasesSafe, formatAssetSize, formatReleaseDate, summarizeReleaseBody } from '../lib/github'
import { siteConfig } from '../data/site'

const releases = await getReleasesSafe()
const latest = releases[0]
const releaseAssets = latest?.assets ?? []
const summaryLines = summarizeReleaseBody(latest?.body ?? null)
---

<BaseLayout
  title="Download Audist"
  description="Get the latest Audist release builds and browse packaged assets."
  path="/download/"
>
  <Header />

  <main class="page-main">
    <section class="page-hero">
      <div class="container page-hero-inner">
        <div>
          <p class="eyebrow">Latest release</p>
          <h1>Download the newest Audist build.</h1>
          <p class="lede">
            Release metadata is fetched from the GitHub Releases API at build time so this page is
            fully static when served from GitHub Pages.
          </p>
        </div>

        {latest ? (
          <aside class="release-highlight">
            <p class="release-label">Current version</p>
            <h2>{latest.name ?? latest.tag_name}</h2>
            <p class="release-date">Published {formatReleaseDate(latest.published_at)}</p>
            <a class="button button-primary full-width" href={latest.html_url} target="_blank" rel="noreferrer">
              Open release on GitHub
            </a>
          </aside>
        ) : (
          <aside class="release-highlight">
            <p class="release-label">Current version</p>
            <h2>No published release yet</h2>
            <p class="release-date">Audist releases will appear here once a tagged build is published.</p>
          </aside>
        )}
      </div>
    </section>

    <section class="section">
      <div class="container download-grid">
        <article class="panel">
          <p class="eyebrow">Assets</p>
          <h2>Release files</h2>
          {releaseAssets.length > 0 ? (
            <div class="asset-list">
              {releaseAssets.map((asset) => (
                <a class="asset-card" href={asset.browser_download_url}>
                  <div>
                    <h3>{asset.name}</h3>
                    <p>{asset.content_type}</p>
                  </div>
                  <div class="asset-meta">
                    <span>{formatAssetSize(asset.size)}</span>
                    <span>{asset.download_count} downloads</span>
                  </div>
                </a>
              ))}
            </div>
          ) : (
            <p class="muted-copy">
              No packaged assets are attached to the latest release yet. Check the{' '}
              <a href={siteConfig.releaseUrl} target="_blank" rel="noreferrer">GitHub releases page</a>{' '}
              for source archives and future binaries.
            </p>
          )}
        </article>

        <article class="panel">
          <p class="eyebrow">Included notes</p>
          <h2>What changed</h2>
          <ul class="summary-list">
            {summaryLines.map((line) => <li>{line}</li>)}
          </ul>
        </article>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
